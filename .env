# ── Vyuhon Environment Variables ──────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the browser.
# Never put secrets or API keys without the VITE_ prefix here.

# App
VITE_APP_NAME=Vyuhon
VITE_APP_URL=https://vyuhon.com

# Contact / Email
VITE_CONTACT_EMAIL=vyuhontech@gmail.com

# Social links
VITE_LINKEDIN_URL=https://www.linkedin.com/company/vyuhon/
VITE_INSTAGRAM_URL=https://www.instagram.com/vyuhon
VITE_TWITTER_URL=https://x.com/vyuhon

# Analytics (optional — add your tracking IDs here)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_HOTJAR_ID=0000000

# Feature flags
VITE_ENABLE_ANIMATIONS=true
